 [[main]
passwordMatcher =*****
passwordService =*****
passwordMatcher.passwordService =*****
authcBasic = flexagon.core.ui.filters.FlexBasicHttpFilter
authcBasic.applicationName = css
authcBasic.enabled = true
noSessionCreation = org.apache.shiro.web.filter.session.NoSessionCreationFilter
noSessionCreation.enabled = true

ds = org.apache.shiro.jndi.JndiObjectFactory
ds.requiredType = javax.sql.DataSource
ds.resourceName = java:comp/env/jdbc/flexdbDS

clients = org.pac4j.core.client.Clients
config = org.pac4j.core.config.Config
config.clients = $clients
pac4jRealm = flexagon.core.security.shiro.realm.FlexSSORealm
pac4jRealm.dataSource = $ds
pac4jRealm.realmName = fdSSO
pac4jRealm.id = 33083162
pac4jSubjectFactory = io.buji.pac4j.subject.Pac4jSubjectFactory
securityManager.subjectFactory = $pac4jSubjectFactory
callbackFilter = org.pac4j.jee.filter.CallbackFilter
callbackFilter.config = $config
pac4jRealm.enableRoleMapping = false


fdRealm = flexagon.core.security.shiro.realm.FlexJdbcRealm
fdRealm.permissionsLookupEnabled = false
fdRealm.authenticationQuery =*****
fdRealm.userRolesQuery = SELECT G.GROUP_NAME FROM ff.flx_group G, ff.FLX_USER_GROUP UG, ff.FLX_USER U WHERE UG.GROUP_ID = G.GROUP_ID AND U.USER_ID = UG.USER_ID AND G.IS_ACTIVE='Y' AND G.APPLICATION_OWNER= 'CSS' AND U.IS_ACTIVE = 'Y' AND UPPER(U.USER_NAME) = UPPER(?)
fdRealm.credentialsMatcher =*****
fdRealm.dataSource = $ds


realmAuthenticator = flexagon.core.security.shiro.extension.FlexRealmAuthenticator
securityManager.authenticator = $realmAuthenticator
authcStrategy = org.apache.shiro.authc.pam.FirstSuccessfulStrategy
securityManager.authenticator.authenticationStrategy = $authcStrategy


securityManager.realms = $pac4jRealm,$fdRealm
cacheManager = flexagon.core.security.shiro.extension.FlexShiroCacheManager
securityManager.cacheManager = $cacheManager

rememberMe = flexagon.core.security.shiro.extension.ExtCookieRememberMeManager
securityManager.rememberMeManager = $rememberMe

sessionManager = org.apache.shiro.web.session.mgt.DefaultWebSessionManager

securityManager.sessionManager = $sessionManager
securityManager.sessionManager.sessionIdUrlRewritingEnabled = false
flexShiroSessionListener = flexagon.core.security.shiro.extension.FlexShiroSessionListener
securityManager.sessionManager.sessionListeners = $flexShiroSessionListener
securityManager.sessionManager.sessionIdCookie.httpOnly = true
securityManager.rememberMeManager.cookie.httpOnly = true

user = flexagon.core.ui.filters.FlexShiroUserFilter
authc.loginUrl = /next/#/login
user.loginUrl = /next/#/login

callbackFilter.defaultUrl = /css
saml2Config=org.pac4j.saml.config.SAML2Configuration
saml2Config.keystorePath = /u01/flexdeploy/keystore/flexdeploy.keystore
saml2Config.keystorePassword =*****
saml2Config.privateKeyPassword =*****
saml2Config.identityProviderMetadataPath = https://login.microsoftonline.com/62968c10-0ab4-4eb8-9ba0-df1240a626eb/federationmetadata/2007-06/federationmetadata.xml?appid=b71c9baa-4889-4d4a-b32b-63969a14fe29
#90 days
saml2Config.maximumAuthenticationLifetime = 15776000
saml2Config.serviceProviderEntityId = spn:b71c9baa-4889-4d4a-b32b-63969a14fe29
saml2Config.serviceProviderMetadataPath = /u01/css/sso/FlexDeployMetadata.xml
saml2Client = org.pac4j.saml.client.SAML2Client
saml2Client.configuration = $saml2Config

clients.callbackUrl = https://fdtlt86.flexagon.azure.com:8448/css/callback
clients.clients = $saml2Client
isAuthenticatedAdmin = org.pac4j.core.authorization.authorizer.IsAuthenticatedAuthorizer
excludedPathMatcher = org.pac4j.core.matching.matcher.PathMatcher
excludedPathMatcher.excludedPath = /next/#/login
config.authorizers = admin:$isAuthenticatedAdmin
config.matchers = excludedPath:$excludedPathMatcher
ssoFilter = flexagon.core.security.shiro.extension.FlexPac4jFilter
ssoFilter.config = $config
ssoFilter.clients = SAML2Client
ssoFilter.matchers = nocache
ssoFilter.authorizers = admin
logout = org.pac4j.jee.filter.LogoutFilter
logout.config = $config
logout.localLogout = true
logout.centralLogout = false
logout.defaultUrl = https://fdtlt86.flexagon.azure.com:8448/css/next/#/home
[urls]
/next/** = anon
/faces/** = ssoFilter
/rest/v1/init = ssoFilter
/fdtestservlet/** = noSessionCreation,authcBasic,user
/rest/v1/login = anon
/rest/v1/login/request-password-reset =*****
/rest/v1/login/password-reset =*****
/rest/v1/server = anon
/rest/v1/registration = anon
/rest/v1/oauth = anon

/rest/v1/logout = noSessionCreation, user
/rest/** = noSessionCreation,authcBasic,user
/webhooks/** = noSessionCreation, anon
/websocket/** = noSessionCreation,authcBasic,user
/callback/** = callbackFilter
/logout = logout
/** = anon
]
